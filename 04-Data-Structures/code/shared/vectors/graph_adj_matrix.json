{
  "name": "adjacency_matrix_undirected",
  "structure": "AdjMatrixGraph",
  "notes": "Constructed with 3 vertices (0..2); addVertex grows the matrix and returns the new vertex's index.",
  "ops": [
    { "op": "construct", "args": [3] },
    { "op": "addEdge", "args": [0, 1] },
    { "op": "addEdge", "args": [1, 2] },
    { "op": "neighbors", "args": [0], "expect": { "list": [1] } },
    { "op": "neighbors", "args": [1], "expect": { "list": [0, 2] } },
    { "op": "vertexCount", "expect": { "value": 3 } },
    { "op": "edgeCount", "expect": { "value": 2 } },
    { "op": "addVertex", "expect": { "value": 3 } },
    { "op": "vertexCount", "expect": { "value": 4 } },
    { "op": "addEdge", "args": [0, 3] },
    { "op": "neighbors", "args": [0], "expect": { "list": [1, 3] } },
    { "op": "edgeCount", "expect": { "value": 3 } },
    { "op": "addEdge", "args": [5, 0], "error": "index" },
    { "op": "neighbors", "args": [10], "error": "index" }
  ]
}
