{
  "name": "bst_insert_delete_inorder",
  "structure": "BST",
  "notes": "Deletion uses in-order successor replacement; tree shape is unbalanced by design (unlike avl.json).",
  "ops": [
    { "op": "construct", "args": [] },
    { "op": "insert", "args": [5], "expect": { "size": 1 } },
    { "op": "insert", "args": [3], "expect": { "size": 2 } },
    { "op": "insert", "args": [8], "expect": { "size": 3 } },
    { "op": "insert", "args": [1], "expect": { "size": 4 } },
    { "op": "insert", "args": [4], "expect": { "size": 5 } },
    { "op": "insert", "args": [7], "expect": { "size": 6 } },
    { "op": "insert", "args": [9], "expect": { "size": 7 } },
    { "op": "insert", "args": [5], "expect": { "size": 7 } },
    { "op": "inorder", "expect": { "list": [1, 3, 4, 5, 7, 8, 9] } },
    { "op": "contains", "args": [4], "expect": { "contains": true } },
    { "op": "contains", "args": [6], "expect": { "contains": false } },
    { "op": "delete", "args": [3], "expect": { "value": true, "size": 6 } },
    { "op": "inorder", "expect": { "list": [1, 4, 5, 7, 8, 9] } },
    { "op": "delete", "args": [3], "expect": { "value": false, "size": 6 } },
    { "op": "delete", "args": [1], "expect": { "value": true, "size": 5 } },
    { "op": "inorder", "expect": { "list": [4, 5, 7, 8, 9] } },
    { "op": "contains", "args": [1], "expect": { "contains": false } },
    { "op": "size", "expect": { "value": 5 } }
  ]
}
