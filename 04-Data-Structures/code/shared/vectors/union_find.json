    { "op": "connected", "args": [0, 1], "expect": { "contains": true } },
    { "op": "union", "args": [1, 2], "expect": { "value": 4 } },
    { "op": "connected", "args": [0, 2], "expect": { "contains": true } },
    { "op": "connected", "args": [0, 3], "expect": { "contains": false } },
    { "op": "union", "args": [3, 4], "expect": { "value": 3 } },
    { "op": "connected", "args": [3, 4], "expect": { "contains": true } },
    { "op": "connected", "args": [0, 4], "expect": { "contains": false } },
    { "op": "union", "args": [0, 4], "expect": { "value": 2 } },
    { "op": "connected", "args": [0, 4], "expect": { "contains": true } },
    { "op": "connected", "args": [2, 3], "expect": { "contains": true } },
    { "op": "count", "expect": { "value": 2 } },
    { "op": "find", "args": [10], "error": "index" }
  ]
}
