{
  "name": "interval-scheduling-activity-selection",
  "algorithm": "interval_scheduling",
  "notes": "Greedy earliest-finish-time; ties broken by lower start then original input index. Touching endpoints (e.g. end=3, next start=3) do not overlap. Certificate isNonOverlapping is also checked.",
  "ops": [
    {
      "op": "intervalScheduling",
      "args": [[[1, 3], [2, 5], [4, 6], [6, 7], [5, 8], [7, 9]]],
      "expect": { "value": [{ "start": 1, "end": 3 }, { "start": 4, "end": 6 }, { "start": 6, "end": 7 }, { "start": 7, "end": 9 }] }
    },
    {
      "op": "intervalScheduling",
      "args": [[[0, 5], [1, 2], [3, 5], [6, 8]]],
      "expect": { "value": [{ "start": 1, "end": 2 }, { "start": 3, "end": 5 }, { "start": 6, "end": 8 }] }
    },
    {
      "op": "intervalScheduling",
      "args": [[{ "start": 0, "end": 1 }]],
      "expect": { "value": [{ "start": 0, "end": 1 }] }
    },
    { "op": "intervalScheduling", "args": [[]], "expect": { "value": [] } }
  ]
}
