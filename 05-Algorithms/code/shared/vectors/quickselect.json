{
  "name": "quickselect-kth-smallest",
  "algorithm": "quickselect",
  "notes": "k is 0-based; deterministic Lomuto partition (no randomized pivot) so exact outputs are stable across runs.",
  "ops": [
    { "op": "quickselect", "args": [[5, 2, 9, 1, 5, 6], 0], "expect": { "value": 1 } },
    { "op": "quickselect", "args": [[5, 2, 9, 1, 5, 6], 2], "expect": { "value": 5 } },
    { "op": "quickselect", "args": [[5, 2, 9, 1, 5, 6], 5], "expect": { "value": 9 } },
    { "op": "quickselect", "args": [[1, 2, 3], -1], "error": "index" },
    { "op": "quickselect", "args": [[1, 2, 3], 3], "error": "index" }
  ]
}
