{
  "name": "dijkstra-shortest-paths",
  "algorithm": "dijkstra",
  "notes": "Args: [n, edges(u,v,w nonneg), src, directed]. Unreachable vertices are null in the result, not +Infinity. Requires non-negative weights.",
  "ops": [
    {
      "op": "dijkstra",
      "args": [4, [[0, 1, 4], [0, 2, 1], [2, 1, 2], [1, 3, 1], [2, 3, 5]], 0, true],
      "expect": { "value": [0, 3, 1, 4] }
    },
    {
      "op": "dijkstra",
      "args": [5, [[0, 1, 4], [0, 2, 1], [2, 1, 2], [1, 3, 1], [2, 3, 5]], 0, true],
      "expect": { "value": [0, 3, 1, 4, null] }
    },
    { "op": "dijkstra", "args": [2, [[0, 1, -1]], 0, true], "error": "invalid" },
    { "op": "dijkstra", "args": [3, [[0, 1]], 5, true], "error": "index" }
  ]
}
